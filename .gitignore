# =========================
# TaskFlow .gitignore
# =========================

# OS files
.DS_Store
Thumbs.db

# IDE / Editors
.vscode/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/

# Visual Studio
.vs/

# =========================
# .NET / C#
# =========================
bin/
obj/
[Bb]uild/
[Ll]og/
[Ll]ogs/
TestResults/
*.trx
*.coverage
*.coveragexml

# NuGet
*.nupkg
packages/
.nuget/packages/

# ASP.NET secrets
secrets.json
appsettings.Development.json
appsettings.Local.json

# Publish output
publish/
*.pubxml
*.pubxml.user

# =========================
# Frontend / Node / React
# =========================
node_modules/
dist/
build/
.vite/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Playwright
playwright-report/
test-results/

# =========================
# Docker / Local Volumes
# =========================
docker-data/
data/
postgres-data/
redis-data/
seq-data/

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Temporary files
# =========================
tmp/
temp/
.cache/